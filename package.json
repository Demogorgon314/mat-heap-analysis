{
  "name": "mat-heap-analysis",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for Eclipse MAT",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mat": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:pack": "npm run build:skill",
    "check:skill": "node scripts/check-skill-release.mjs",
    "check:pack": "npm run check:skill",
    "build:skill": "node scripts/build-skill-runtime.mjs",
    "dev": "tsx src/cli.ts",
    "release:pack": "node scripts/release-skill.mjs",
    "release:skill": "node scripts/release-skill.mjs",
    "start": "node dist/cli.js",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^13.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.15.3",
    "esbuild": "^0.25.1",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  }
}
