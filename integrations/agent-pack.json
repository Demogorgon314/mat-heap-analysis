{
  "name": "mat-heap-analysis",
  "description": "Portable agent runtime for Eclipse MAT heap analysis",
  "runtime": {
    "launcher": "skills/mat-heap-analysis/scripts/mat.cjs",
    "shell_wrapper": "skills/mat-heap-analysis/scripts/mat",
    "bundle": "skills/mat-heap-analysis/assets/runtime/mat.cjs"
  },
  "prompt": {
    "vendor_neutral": "integrations/MAT_AGENT_PROMPT.md"
  },
  "hosts": [
    "claude",
    "codex",
    "opencode"
  ],
  "discovery": [
    "node scripts/mat.cjs",
    "node scripts/mat.cjs catalog --json",
    "node scripts/mat.cjs <command> --help"
  ],
  "recommended_workflow": [
    "doctor",
    "index",
    "report org.eclipse.mat.api:overview",
    "report org.eclipse.mat.api:suspects",
    "run histogram",
    "run path2gc --args 0x...",
    "query --query 'SELECT ...'"
  ]
}
